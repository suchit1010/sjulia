# Environment Configuration Template
# Copy this file to .env and fill in your API keys

# JuliaOS Configuration
JULIAOS_HOST=http://127.0.0.1:8052/api/v1
JULIAOS_TIMEOUT=30

# OpenAI Configuration (Required)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# Blockchain Configuration
# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=your_solana_private_key_here

# Ethereum (Sepolia Testnet)
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
ETHEREUM_PRIVATE_KEY=your_ethereum_private_key_here

# DEX API Keys (Optional - for enhanced features)
UNISWAP_API_KEY=your_uniswap_api_key_here
JUPITER_API_URL=https://price.jup.ag/v4

# Dashboard Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_DEBUG=true

# Risk Management
MAX_TRADE_SIZE_USD=1000
MAX_PORTFOLIO_RISK=0.05
ENABLE_REAL_TRADING=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/portfolio_manager.log

# Performance Monitoring
ENABLE_METRICS=true
METRICS_PORT=8080
